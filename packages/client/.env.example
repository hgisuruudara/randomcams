VITE_SERVER_URL=http://localhost:4000

# Must match GOOGLE_CLIENT_ID in the server's env.
VITE_GOOGLE_CLIENT_ID=

# Optional TURN server (see the coturn service in docker-compose.yml for a
# local one). Without this, WebRTC falls back to STUN-only, which fails to
# connect a meaningful fraction of real-world users behind restrictive
# NATs/firewalls. Leave blank for local development between two browser tabs
# on the same machine, where STUN is unnecessary anyway.
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
