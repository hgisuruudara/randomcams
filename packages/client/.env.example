VITE_SERVER_URL=http://localhost:4000

# Must match GOOGLE_CLIENT_ID in the server's env.
VITE_GOOGLE_CLIENT_ID=

# TURN is configured on the server (TURN_SECRET/TURN_URLS in
# packages/server/.env.example), not here - the client fetches short-lived
# TURN credentials at runtime from GET /webrtc/turn-credentials instead of
# a static value baked into the build. See src/hooks/useIceServers.ts.
