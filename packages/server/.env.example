PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Generate a real random secret for any non-local environment, e.g.
# `openssl rand -hex 32`. Never reuse this placeholder.
JWT_SECRET=dev-only-change-me

# Shared secret gating /admin/moderation/* - a stopgap until there's real
# per-admin staff auth. Generate with `openssl rand -hex 32`. Leave unset to
# keep the admin API disabled (it returns 503 rather than being open).
ADMIN_TOKEN=

# OAuth 2.0 Client ID from https://console.cloud.google.com/apis/credentials
# (Web application type). Must match VITE_GOOGLE_CLIENT_ID in the client's env.
# Google Sign-In only authenticates the user - it never sets verified
# gender/age, which still requires the KYC flow below.
GOOGLE_CLIENT_ID=

DATABASE_URL=postgresql://randomcams:randomcams@localhost:5432/randomcams
REDIS_URL=redis://localhost:6379

# Set to "mock" for local development. Swap to a real vendor id (e.g. "veriff",
# "persona", "yoti") once credentials below are filled in and the matching
# provider implementation in src/verification/providers/ is wired up.
KYC_PROVIDER=mock
KYC_API_KEY=
KYC_WEBHOOK_SECRET=
