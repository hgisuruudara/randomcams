# Copy to .env.production and fill in real values. Never commit the real
# file. Used by: docker compose --env-file .env.production -f docker-compose.prod.yml up -d

POSTGRES_USER=randomcams
POSTGRES_PASSWORD=
POSTGRES_DB=randomcams

# The public URL end users hit - same domain the edge nginx terminates TLS
# for (see deploy/nginx/edge.conf). Also becomes the client's build-time
# VITE_SERVER_URL, so client and API share an origin through the edge proxy.
CLIENT_ORIGIN=https://example.com

# openssl rand -hex 32
JWT_SECRET=
ADMIN_TOKEN=

GOOGLE_CLIENT_ID=

# See packages/server/src/verification/provider.ts - "mock" is not valid in
# production, a real KycProvider implementation must be wired in first.
KYC_PROVIDER=
KYC_API_KEY=
KYC_WEBHOOK_SECRET=

# TURN REST API auth (coturn --use-auth-secret mode - see docker-compose.prod.yml
# and packages/server/src/webrtc/turnCredentials.ts). The client never sees
# this secret; it fetches short-lived derived credentials from the server.
# openssl rand -hex 32
TURN_SECRET=
# Comma-separated if you run TURN over both UDP and TCP, e.g.
# turn:example.com:3478?transport=udp,turn:example.com:3478?transport=tcp
TURN_URLS=turn:example.com:3478
TURN_REALM=example.com
# Optional, defaults to 6 hours.
TURN_CREDENTIAL_TTL_SECONDS=21600
