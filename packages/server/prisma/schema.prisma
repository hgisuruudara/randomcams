generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ModerationReportReason {
  NUDITY_OR_SEXUAL_CONTENT_WITHOUT_CONSENT
  SUSPECTED_MINOR
  HARASSMENT
  SCAM_OR_SOLICITATION
  OTHER
}

enum ModerationReportStatus {
  // Default queue for anything a user reports. A human reviews these before
  // any account action is taken.
  PENDING_REVIEW
  // Reserved for the automated CSAM-classifier path (see moderation/csamHook.ts).
  // These bypass human review entirely: auto-suspend + mandatory report, no delay.
  ESCALATED_AUTOMATIC
  ACTION_TAKEN
  DISMISSED
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  // Null for accounts created via Google Sign-In that never set a password.
  passwordHash      String?
  // Set only for accounts that signed in with Google at least once. Used to
  // find-or-link an account on subsequent Google logins.
  googleId          String?            @unique
  displayName       String
  createdAt         DateTime           @default(now())
  banned            Boolean            @default(false)
  bannedAt          DateTime?

  verificationStatus VerificationStatus @default(UNVERIFIED)
  verifiedGender     Gender?
  // Raw DOB is sensitive PII kept only for compliance (age re-checks, legal
  // record-keeping). Encrypt at rest / restrict access in production.
  verifiedBirthdate  DateTime?

  // Consent record for the ToS/Privacy Policy shown at signup. tosVersion
  // lets a re-acceptance requirement be added later if those documents
  // change materially - do not backfill old accounts as having accepted a
  // newer version.
  tosAcceptedAt      DateTime?
  tosVersion         String?

  // Informational/security hygiene only - NOT a gate on using the app. The
  // real "is this a real, age-verified adult" gate is verificationStatus
  // above (KYC). Email verification just confirms the address is reachable,
  // which password-reset delivery depends on.
  emailVerifiedAt              DateTime?
  emailVerificationTokenHash   String?
  emailVerificationExpiresAt   DateTime?

  passwordResetTokenHash   String?
  passwordResetExpiresAt   DateTime?

  // Bumped on password reset and on an explicit "log out everywhere"
  // request. Included in every issued JWT; a mismatch against the current
  // DB value means the token was issued before a revocation event and is
  // rejected, even though the JWT signature itself is still valid.
  tokenVersion       Int                @default(0)

  verificationRecords VerificationRecord[]
  reportsFiled        ModerationReport[] @relation("reporter")
  reportsReceived      ModerationReport[] @relation("reportedUser")
  sessionsAsA         ChatSession[]      @relation("sessionUserA")
  sessionsAsB         ChatSession[]      @relation("sessionUserB")
}

model VerificationRecord {
  id                 String             @id @default(cuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id])
  provider           String
  providerReference  String
  status             VerificationStatus
  extractedGender    Gender?
  extractedBirthdate DateTime?
  createdAt          DateTime           @default(now())

  @@index([userId])
}

model ChatSession {
  id        String   @id @default(cuid())
  userAId   String
  userA     User     @relation("sessionUserA", fields: [userAId], references: [id])
  userBId   String
  userB     User     @relation("sessionUserB", fields: [userBId], references: [id])
  startedAt DateTime @default(now())
  endedAt   DateTime?

  reports ModerationReport[]

  @@index([userAId])
  @@index([userBId])
}

model ModerationReport {
  id             String                  @id @default(cuid())
  sessionId      String
  session        ChatSession             @relation(fields: [sessionId], references: [id])
  reporterId     String
  reporter       User                    @relation("reporter", fields: [reporterId], references: [id])
  reportedUserId String
  reportedUser   User                    @relation("reportedUser", fields: [reportedUserId], references: [id])
  reason         ModerationReportReason
  note           String?
  status         ModerationReportStatus  @default(PENDING_REVIEW)
  // Pointer to evidence (clip/screenshot) in secure storage — never store
  // raw media in the primary DB.
  evidenceRef    String?
  reviewedByAdminId String?
  reviewedAt     DateTime?
  createdAt      DateTime                @default(now())

  @@index([reportedUserId])
  @@index([status])
}
